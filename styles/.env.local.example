# ── Supabase (optional when running on plain PostgreSQL) ──────────────────────
# If NEXT_PUBLIC_SUPABASE_URL is set, the app uses the Supabase client for
# database queries (profiles, products, etc.).  Leave these blank when running
# against a plain PostgreSQL server — the app will use DATABASE_URL directly.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only key that bypasses RLS. Required when Supabase URL is set.
SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key   # fallback alias

# ── Database (required) ───────────────────────────────────────────────────────
# Used by Better Auth and as the direct pg fallback when Supabase is not configured.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Better Auth (required) ────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ── Cloudflare Turnstile (required for customer auth) ────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── SMTP (Better Auth password reset emails) ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Media uploads (MinIO / S3-compatible storage) ─────────────────────────────
MEDIA_STORAGE_DRIVER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=saco-media
MINIO_PUBLIC_BASE_URL=http://localhost:9000/saco-media
MINIO_FORCE_PATH_STYLE=true

# ── Optional diagnostics ──────────────────────────────────────────────────────
DEBUG_PERFORMANCE=false
SUPABASE_LATENCY_RUNS=5
EXTERNAL_REQUEST_TIMEOUT_MS=20000
AUTH_REQUEST_TIMEOUT_MS=25000
PUBLIC_DATA_TIMEOUT_MS=20000
ADMIN_MUTATION_TIMEOUT_MS=30000
FILE_OPERATION_TIMEOUT_MS=15000
SUPABASE_LATENCY_CONCURRENCY=3
